rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getRole() {
      return getUserData().role;
    }

    function isAdmin() {
      return isAuthenticated() && getRole() == 'admin';
    }

    function isEmployee() {
      return isAuthenticated() && getRole() == 'employee';
    }

    function isViewer() {
      return isAuthenticated() && getRole() == 'viewer';
    }

    function canWrite() {
      return isAdmin() || isEmployee();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users Collection
    match /users/{userId} {
      // Only admin can read or write users
      allow read, write: if isAdmin();
      // Allow user to read their own document to check role/status
      allow read: if isAuthenticated() && request.auth.uid == userId;
    }

    // Blacklist Collection
    match /blacklist/{docId} {
      allow read: if isAuthenticated(); // viewers can read
      allow write: if canWrite();       // admin, employee can write
    }

    // Audit Logs Collection
    match /audit_logs/{logId} {
      allow read: if isAuthenticated(); // all auth users can read
      // admin, employee can write (create), no one can delete
      allow create: if canWrite();
      allow update: if false;
      allow delete: if false;
    }
  }
}
